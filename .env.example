# Telegram Bot
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather

# Supabase
SUPABASE_URL=your_supabase_project_url
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_KEY=your_supabase_service_role_key

# Public web URL where the Mini App is hosted (Vercel deployment).
# The bot uses this for the "Open Tests" inline button.
WEB_APP_URL=https://your-app.vercel.app

# Comma-separated Telegram user IDs allowed to upload PDFs to create tests.
# Get your ID by sending /whoami to your bot once. Other users can only TAKE
# tests, not create them.
ADMIN_TELEGRAM_IDS=123456789

# Anthropic API key — used as a fallback when an uploaded file contains only
# questions (no answer markers). The bot sends the questions to Claude, which
# generates 4 multiple-choice options + the correct answer for each. Skip if
# you only ever upload PDFs with explicit Javob:/Answer: lines.
# Get one at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Local server (used by the legacy bot/server folders for local dev only)
PORT=3000
